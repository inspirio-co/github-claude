# Server
WEBHOOK_PORT=3031
GITHUB_WEBHOOK_SECRET=your-secret

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_BASE_BRANCH=main

# Workspace (local clone path)
WORKSPACE_DIR=/home/ubuntu/your-project

# Labels
LABEL_TRIGGER=auto-fix
LABEL_IN_PROGRESS=status/in-progress
LABEL_DONE=status/done
LABEL_NEEDS_REVIEW=status/needs-review

# Claude Code
CLAUDE_ALLOWED_TOOLS=Edit,Write,Glob,Grep,Read
CLAUDE_REVIEW_TOOLS=Glob,Grep,Read
CLAUDE_TIMEOUT=600000
CLAUDE_MAX_RETRIES=3
BRANCH_PREFIX=auto-fix

# Feature Flags
ENABLE_PR=true
ENABLE_REVIEW=true
ENABLE_BUILD=true
ENABLE_QA=true

# Build & Deploy
BUILD_COMMAND=npm install && npm run build
DEPLOY_COMMAND=

# Backend inline fix (optional)
# 프론트 이슈의 근본원인이 백엔드일 때, fix 에이전트가 백엔드 레포까지 수정하고
# 별도 PR·빌드·(빌드 성공 시)머지+배포를 자동 수행한다.
# BACKEND_FIX_ENABLED 미설정 시: <WORKSPACE_DIR 형제>/<BACKEND_REPO> 에 git 레포가 있으면 자동 활성화.
# BACKEND_DEPLOY_COMMAND 미설정 시: 빌드+머지까지만 하고 배포는 스킵.
BACKEND_FIX_ENABLED=true
BACKEND_REPO=your-backend-repo
BACKEND_WORKSPACE_DIR=/home/ubuntu/your-backend
BACKEND_BASE_BRANCH=main
BACKEND_BUILD_COMMAND=npm install && npm run build
BACKEND_DEPLOY_COMMAND=

# QA (QuestCode)
QUESTCODE_API_TOKEN=your-questcode-token
QUESTCODE_BASE_URL=https://your-questcode-instance.com
QA_TARGET_URL=https://your-app-url.com
QA_CREDENTIAL_ID=
QA_POLL_TIMEOUT=300000
QA_POLL_INTERVAL=15000
QA_MAX_RETRIES=2
